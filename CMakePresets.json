{
  "version": 2,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug build with compile commands for editor integration.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug-asan",
      "displayName": "Debug + sanitizers",
      "description": "Debug build with AddressSanitizer, LeakSanitizer, and UndefinedBehaviorSanitizer.",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/debug-asan",
      "cacheVariables": {
        "COVOCA_ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "debug-tidy",
      "displayName": "Debug + clang-tidy",
      "description": "Debug build that runs clang-tidy during compilation.",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/debug-tidy",
      "cacheVariables": {
        "CMAKE_CXX_CLANG_TIDY": "clang-tidy;--quiet"
      }
    },
    {
      "name": "debug-vcpkg",
      "displayName": "Debug + vcpkg",
      "description": "Debug build using the vcpkg manifest. Requires VCPKG_ROOT.",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/debug-vcpkg",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Optimized release build with compile commands for editor integration.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "release-vcpkg",
      "displayName": "Release + vcpkg",
      "description": "Release build using the vcpkg manifest. Requires VCPKG_ROOT.",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/release-vcpkg",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "configurePreset": "debug"
    },
    {
      "name": "debug-asan",
      "displayName": "Debug + sanitizers",
      "configurePreset": "debug-asan"
    },
    {
      "name": "debug-tidy",
      "displayName": "Debug + clang-tidy",
      "configurePreset": "debug-tidy"
    },
    {
      "name": "debug-vcpkg",
      "displayName": "Debug + vcpkg",
      "configurePreset": "debug-vcpkg"
    },
    {
      "name": "debug-aruco-calibrate",
      "displayName": "Debug: aruco_calibrate",
      "configurePreset": "debug",
      "targets": [
        "aruco_calibrate"
      ]
    },
    {
      "name": "release",
      "displayName": "Release",
      "configurePreset": "release"
    },
    {
      "name": "release-vcpkg",
      "displayName": "Release + vcpkg",
      "configurePreset": "release-vcpkg"
    },
    {
      "name": "release-aruco-calibrate",
      "displayName": "Release: aruco_calibrate",
      "configurePreset": "release",
      "targets": [
        "aruco_calibrate"
      ]
    }
  ]
}
