{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Make: project",
      "type": "shell",
      "command": "make",
      "args": [
        "project"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Make: release",
      "type": "shell",
      "command": "make",
      "args": [
        "release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Make: run",
      "type": "shell",
      "command": "make",
      "args": [
        "run"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Make: docs",
      "type": "shell",
      "command": "make",
      "args": [
        "docs"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
