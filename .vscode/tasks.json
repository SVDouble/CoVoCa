{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Make: project",
      "type": "shell",
      "command": "make",
      "args": [
        "project"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Make: release",
      "type": "shell",
      "command": "make",
      "args": [
        "release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Make: run",
      "type": "shell",
      "command": "make",
      "args": [
        "run"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Make: format-check",
      "type": "shell",
      "command": "make",
      "args": [
        "format-check"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Make: lint",
      "type": "shell",
      "command": "make",
      "args": [
        "lint"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Make: sanitize",
      "type": "shell",
      "command": "make",
      "args": [
        "sanitize"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Make: memcheck",
      "type": "shell",
      "command": "make",
      "args": [
        "memcheck"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Make: quality",
      "type": "shell",
      "command": "make",
      "args": [
        "quality"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Make: docs",
      "type": "shell",
      "command": "make",
      "args": [
        "docs"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
